{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(flutter analyze:*)",
      "Bash(flutter pub run:*)",
      "Bash(dart run:*)",
      "Bash(flutter test *)",
      "Bash(dart analyze)",
      "Bash(git diff *)",
      "Bash(grep *)",
      "Bash(find *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}